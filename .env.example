# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=loguser
POSTGRES_PASSWORD=logpassword
POSTGRES_DB=logsdb

# ─── Backend ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://loguser:logpassword@db:5432/logsdb
CORS_ORIGINS=http://localhost:3000
ENV=development

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
